{
  "buildCommand": "npm run build",
  "outputDirectory": "build",
  "devCommand": "npm start",
  "installCommand": "npm install",
  "framework": "create-react-app",
  "rewrites": [
    {
      "source": "/((?!static|asset-manifest|manifest|favicon|logo).*)",
      "destination": "/index.html"
    }
  ]
}